<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.RolePermissionMapper">

    <insert id="insert" parameterType="com.example.entity.RolePermission">
        INSERT INTO role_permission (role_id, perm_id)
        VALUES (#{roleId}, #{permId})
    </insert>

    <delete id="delete">
        DELETE FROM role_permission WHERE role_id = #{roleId} AND perm_id = #{permId}
    </delete>

    <delete id="deleteByRoleId">
        DELETE FROM role_permission WHERE role_id = #{roleId}
    </delete>

    <select id="selectPermIdsByRoleId" resultType="java.lang.Long">
        SELECT perm_id FROM role_permission WHERE role_id = #{roleId}
    </select>

</mapper>
