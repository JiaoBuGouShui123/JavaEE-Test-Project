<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dao.RoleMapper">

    <resultMap id="roleMap" type="com.example.entity.Role">
        <id property="roleId" column="role_id"/>
        <result property="roleName" column="role_name"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectById" resultMap="roleMap">
        SELECT * FROM role WHERE role_id = #{roleId}
    </select>

    <select id="selectAll" resultMap="roleMap">
        SELECT * FROM role ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.example.entity.Role"
            useGeneratedKeys="true" keyProperty="roleId">
        INSERT INTO role (role_name, description, create_time)
        VALUES (#{roleName}, #{description}, #{createTime})
    </insert>

    <update id="update" parameterType="com.example.entity.Role">
        UPDATE role
        <set>
            <if test="roleName != null and roleName != ''">role_name = #{roleName},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE role_id = #{roleId}
    </update>

    <delete id="deleteById">
        DELETE FROM role WHERE role_id = #{roleId}
    </delete>

    <select id="selectByUserId" resultMap="roleMap">
        SELECT r.* FROM role r
        INNER JOIN user_role ur ON r.role_id = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>

</mapper>
